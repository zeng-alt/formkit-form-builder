{
  "name": "@zeng-alt/formkit-form-builder",
  "version": "0.1.0",
  "description": "A visual FormKit schema builder for Vue 3",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zeng-alt/formkit-form-builder.git"
  },
  "keywords": [
    "vue",
    "vue3",
    "formkit",
    "form-builder",
    "schema",
    "drag-and-drop"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "oxfmt src/"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "@vueuse/core": "^14.2.1",
    "naive-ui": "^2.44.0"
  },
  "dependencies": {
    "@internationalized/date": "^3.12.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^1.0.0",
    "openai": "^6.34.0",
    "tailwind-merge": "^3.5.0",
    "vue-sonner": "^2.0.9",
    "@formkit/core": "^2.0.0",
    "@formkit/vue": "^2.0.0",
    "@formkit/drag-and-drop": "^0.5.0"
  },
  "devDependencies": {
    "@vueuse/core": "^14.2.1",
    "@formkit/core": "^2.0.0",
    "@formkit/drag-and-drop": "^0.5.3",
    "@formkit/vue": "^2.0.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.57.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.42.0",
    "oxlint": "~1.57.0",
    "typescript": "~6.0.0",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6",
    "tailwindcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "naive-ui": "^2.44.1",
    "vue": "^3.5.31"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
